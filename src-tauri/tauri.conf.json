{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDFParse",
  "version": "0.1.0",
  "identifier": "com.pdfparse.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:desktop",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PDFParse",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "sidecar/pdfparse-parser"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
